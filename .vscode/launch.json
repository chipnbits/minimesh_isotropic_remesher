//
// This file sets up the debugger for vscode
// See https://github.com/Microsoft/vscode-cpptools/blob/master/launch.md
//
{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Debug Current File Context",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "program": "${input:selectProgram}",
      "cwd": "${workspaceFolder}",
      "args": ["${workspaceFolder}/mesh/cube.obj"],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "externalConsole": false
    },
    {
      "name": "Debug GUI",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "program": "${workspaceFolder}/build-dbg/bin/minimeshgui",
      "cwd": "${workspaceFolder}",
      "args": ["${workspaceFolder}/mesh/cube.obj"],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "externalConsole": false
    },
    {
      "name": "Debug CLI",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "program": "${workspaceFolder}/build-dbg/bin/minimeshcli",
      "cwd": "${workspaceFolder}",
      "args": ["${workspaceFolder}/mesh/cube.obj"],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "externalConsole": false
    },
    {
      "name": "Debug Tests",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "program": "${workspaceFolder}/build-dbg/src/minimesh/test/minimesh_tests",
      "cwd": "${workspaceFolder}",
      "args": [],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "externalConsole": false
    }
  ],
  "inputs": [
    {
      "id": "selectProgram",
      "description": "Select program to debug",
      "type": "pickString",
      "options": [
        {
          "label": "CLI (minimeshcli)",
          "value": "${workspaceFolder}/build-dbg/bin/minimeshcli"
        },
        {
          "label": "GUI (minimeshgui)",
          "value": "${workspaceFolder}/build-dbg/bin/minimeshgui"
        },
        {
          "label": "Tests (minimesh_tests)",
          "value": "${workspaceFolder}/build-dbg/src/minimesh/test/minimesh_tests"
        }
      ]
    }
  ]
}
