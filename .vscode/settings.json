{
  // --- CMake / run args ---
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,
  "cmake.defaultConfigurePreset": "debug",
  "cmake.defaultBuildPreset": "debug",
  "cmake.buildBeforeRun": true,
  "cmake.defaultBuildTarget": "minimeshgui",
  "cmake.runConfig":  { "args": ["${workspaceFolder}/mesh/cube.obj"], "cwd": "${workspaceFolder}" },
  "cmake.debugConfig":{ "args": ["${workspaceFolder}/mesh/cube.obj"], "cwd": "${workspaceFolder}" },
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",

  // --- cpptools off for IntelliSense; keep for debugging ---
  "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.clang_format_style": "file",
  "C_Cpp.clang_format_fallbackStyle": "Google",

  // --- Hide/unhide files in Explorer ---
  "files.exclude": {
    "**/*~": true,
    "**/#*": true,
    "build-dbg": false,
    "build-opt": false,
    "third-party.zip": true,
    "third-party": true,
    "debugger": false,
    "webpage": true,
    "mesh": false
  },

  // --- Make config files open as JSON/JSONC; keep your C++ mappings below ---
  "files.associations": {
    "CMakePresets.json": "json",
    "CMakeUserPresets.json": "json",
    "launch.json": "jsonc",
    "tasks.json": "jsonc",
    "settings.json": "jsonc",

    "armadillo": "cpp",
    "*.ipp": "cpp",
    "*.tcc": "cpp",
    "cctype": "cpp",
    "clocale": "cpp",
    "cmath": "cpp",
    "csignal": "cpp",
    "cstdarg": "cpp",
    "cstddef": "cpp",
    "cstdio": "cpp",
    "cstdlib": "cpp",
    "cstring": "cpp",
    "ctime": "cpp",
    "cwchar": "cpp",
    "cwctype": "cpp",
    "array": "cpp",
